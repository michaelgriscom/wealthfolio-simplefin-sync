{
  "name": "wealthfolio-simplefin-sync",
  "version": "0.1.0",
  "description": "Sync investment holdings from SimpleFIN Bridge into Wealthfolio as dated holdings snapshots.",
  "type": "module",
  "private": true,
  "main": "dist/addon.js",
  "author": "Michael Griscom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelgriscom/wealthfolio-simplefin-sync.git"
  },
  "keywords": [
    "wealthfolio",
    "addon",
    "simplefin",
    "investments",
    "asset-allocation"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "dev:server": "wealthfolio dev",
    "clean": "rm -rf dist",
    "package": "mkdir -p dist && zip -r dist/$npm_package_name-$npm_package_version.zip manifest.json dist/ README.md",
    "bundle": "pnpm clean && pnpm build && pnpm package",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@wealthfolio/addon-sdk": "^3.5.1",
    "@wealthfolio/ui": "^3.5.1"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@wealthfolio/addon-dev-tools": "^3.5.1",
    "rollup-plugin-external-globals": "^0.13.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "files": [
    "dist/",
    "manifest.json",
    "README.md"
  ]
}
